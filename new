<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Interbank Fraud Intelligence Network</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#0B1221;          /* midnight base */
    --panel:#141E33;        /* raised panel */
    --panel-2:#1B2740;
    --gold:#E8C07D;         /* protected identity / value */
    --cyan:#5FD3C4;         /* live network signal */
    --text:#EAF0F7;
    --muted:#8294B0;
    --line:rgba(234,240,247,.10);
    --display:'Space Grotesk',system-ui,sans-serif;
    --body:'Inter',system-ui,sans-serif;
    --mono:'IBM Plex Mono',monospace;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html,body{height:100%}
  body{
    background:var(--ink);
    color:var(--text);
    font-family:var(--body);
    overflow:hidden;
    -webkit-font-smoothing:antialiased;
  }
  #bg{position:fixed;inset:0;z-index:0;opacity:.55}

  /* ---- deck shell ---- */
  .deck{position:relative;z-index:1;height:100%;width:100%}
  .slide{
    position:absolute;inset:0;
    display:flex;flex-direction:column;justify-content:center;
    padding:clamp(28px,6vw,92px);
    opacity:0;visibility:hidden;
    transform:translateY(14px);
    transition:opacity .55s ease,transform .55s ease,visibility .55s;
    pointer-events:none;
  }
  .slide.active{opacity:1;visibility:visible;transform:none;pointer-events:auto}
  .wrap{max-width:1040px;margin:0 auto;width:100%}

  /* staggered reveal of children when slide is active */
  .slide [data-reveal]{opacity:0;transform:translateY(16px);transition:opacity .6s ease,transform .6s ease}
  .slide.active [data-reveal]{opacity:1;transform:none}
  .slide.active [data-reveal]:nth-child(1){transition-delay:.10s}
  .slide.active [data-reveal]:nth-child(2){transition-delay:.20s}
  .slide.active [data-reveal]:nth-child(3){transition-delay:.30s}
  .slide.active [data-reveal]:nth-child(4){transition-delay:.40s}
  .slide.active [data-reveal]:nth-child(5){transition-delay:.50s}
  .slide.active [data-reveal]:nth-child(6){transition-delay:.60s}

  .eyebrow{
    font-family:var(--mono);font-size:13px;letter-spacing:.22em;
    text-transform:uppercase;color:var(--cyan);margin-bottom:22px;
    display:flex;align-items:center;gap:12px;
  }
  .eyebrow::before{content:"";width:30px;height:1px;background:var(--cyan);opacity:.7}

  h1{font-family:var(--display);font-weight:700;line-height:1.02;letter-spacing:-.02em}
  .title-xl{font-size:clamp(40px,7vw,84px)}
  h2{font-family:var(--display);font-weight:600;font-size:clamp(30px,5vw,58px);line-height:1.05;letter-spacing:-.015em}
  .lead{font-size:clamp(17px,2.1vw,23px);line-height:1.55;color:var(--text);max-width:760px;margin-top:24px;font-weight:400}
  .muted{color:var(--muted)}
  .gold{color:var(--gold)}
  .cyan{color:var(--cyan)}
  .sub{font-size:clamp(16px,2vw,20px);color:var(--muted);margin-top:20px;max-width:680px;line-height:1.5}

  /* ---- slide 1 ---- */
  .meta-row{margin-top:38px;display:flex;gap:10px;flex-wrap:wrap}
  .chip{font-family:var(--mono);font-size:12.5px;letter-spacing:.08em;color:var(--muted);
    border:1px solid var(--line);border-radius:999px;padding:7px 14px;background:rgba(255,255,255,.02)}

  /* ---- problem: hopping banks ---- */
  .banks{display:flex;align-items:center;justify-content:center;gap:clamp(20px,6vw,80px);margin:46px 0 8px}
  .bank{width:clamp(86px,14vw,128px);height:clamp(86px,14vw,128px);border-radius:20px;
    background:var(--panel);border:1px solid var(--line);display:flex;flex-direction:column;
    align-items:center;justify-content:center;gap:8px;position:relative}
  .bank svg{width:34px;height:34px}
  .bank span{font-family:var(--mono);font-size:12px;color:var(--muted);letter-spacing:.05em}
  .hop{position:absolute;top:-14px;left:50%;width:26px;height:26px;border-radius:50%;
    background:var(--cyan);transform:translateX(-50%);box-shadow:0 0 0 0 rgba(95,211,196,.5)}
  .slide.active .hop{animation:hop 3.4s ease-in-out infinite}
  @keyframes hop{
    0%{left:16%;background:var(--gold)} 
    30%{left:16%} 
    33%{background:#ff7a7a} 
    50%{left:50%} 
    66%{left:50%} 
    83%{left:84%} 
    100%{left:84%}
  }
  .bank-line{height:1px;background:var(--line);flex:1;min-width:24px}

  /* ---- privacy block ---- */
  .swap{display:flex;align-items:center;justify-content:center;gap:26px;margin:46px 0 6px;flex-wrap:wrap}
  .doc{font-family:var(--mono);font-size:13px;color:var(--muted);background:var(--panel);
    border:1px solid var(--line);border-radius:14px;padding:18px 22px;line-height:1.7;text-align:left}
  .doc b{color:var(--text);font-weight:500}
  .barrier{display:flex;flex-direction:column;align-items:center;gap:8px;color:#ff8585}
  .barrier .ban{width:54px;height:54px;border:2.5px solid #ff8585;border-radius:50%;position:relative}
  .barrier .ban::after{content:"";position:absolute;top:50%;left:-4px;right:-4px;height:2.5px;background:#ff8585;transform:rotate(-45deg)}
  .barrier small{font-family:var(--mono);font-size:11px;letter-spacing:.1em}

  /* ---- tokenizer (signature) ---- */
  .tok{display:flex;align-items:center;justify-content:center;gap:clamp(16px,4vw,44px);margin:44px 0 10px;flex-wrap:wrap}
  .tok-card{background:var(--panel);border:1px solid var(--line);border-radius:16px;padding:24px 26px;min-width:230px;text-align:center}
  .tok-card .label{font-family:var(--mono);font-size:11px;letter-spacing:.16em;text-transform:uppercase;margin-bottom:14px}
  .tok-id .label{color:var(--gold)} .tok-out .label{color:var(--cyan)}
  .tok-val{font-family:var(--mono);font-size:clamp(18px,2.6vw,26px);font-weight:500;letter-spacing:.02em}
  .tok-id .tok-val{color:var(--gold)} .tok-out .tok-val{color:var(--cyan)}
  .arrow{display:flex;flex-direction:column;align-items:center;gap:8px;color:var(--muted)}
  .arrow .lock{width:42px;height:42px;border-radius:12px;background:var(--panel-2);border:1px solid var(--line);
    display:flex;align-items:center;justify-content:center}
  .arrow .lock svg{width:20px;height:20px;stroke:var(--gold)}
  .arrow .one-way{font-family:var(--mono);font-size:10.5px;letter-spacing:.12em;color:var(--muted);text-transform:uppercase}
  .arrow .track{position:relative;width:clamp(60px,9vw,110px);height:2px;background:var(--line)}
  .arrow .track::after{content:"";position:absolute;top:-3px;right:-1px;border:4px solid transparent;border-left-color:var(--cyan)}
  .slide.active .arrow .pulse{position:absolute;top:-2px;left:0;width:8px;height:8px;border-radius:50%;background:var(--cyan);
    animation:flow 2.2s ease-in-out infinite}
  @keyframes flow{0%{left:0;opacity:0}15%{opacity:1}85%{opacity:1}100%{left:100%;opacity:0}}

  /* ---- ledger ---- */
  .ledger{margin:40px 0 6px;display:flex;flex-direction:column;gap:10px;max-width:620px}
  .row-led{display:flex;align-items:center;gap:14px;background:var(--panel);border:1px solid var(--line);
    border-radius:12px;padding:14px 18px;font-family:var(--mono);font-size:14px}
  .row-led .dot{width:9px;height:9px;border-radius:50%;background:var(--cyan);flex:none;box-shadow:0 0 10px var(--cyan)}
  .row-led .h{color:var(--gold)} .row-led .t{color:var(--muted);margin-left:auto;font-size:12px}
  .chain-note{display:flex;gap:18px;flex-wrap:wrap;margin-top:22px}
  .chain-note div{font-size:15px;color:var(--muted)}
  .chain-note b{color:var(--text);font-weight:500}

  /* ---- in action steps ---- */
  .steps{display:flex;gap:18px;margin:42px 0 6px;flex-wrap:wrap}
  .step{flex:1;min-width:210px;background:var(--panel);border:1px solid var(--line);border-radius:16px;padding:24px;position:relative;overflow:hidden}
  .step .n{font-family:var(--mono);font-size:13px;color:var(--cyan);letter-spacing:.1em}
  .step h3{font-family:var(--display);font-size:19px;font-weight:600;margin:12px 0 8px}
  .step p{font-size:14.5px;color:var(--muted);line-height:1.5}
  .step .sheen{position:absolute;inset:0;background:linear-gradient(120deg,transparent 40%,rgba(95,211,196,.10) 50%,transparent 60%);transform:translateX(-100%)}
  .slide.active .step .sheen{animation:sheen 2.6s ease-in-out infinite}
  .slide.active .step:nth-child(2) .sheen{animation-delay:.5s}
  .slide.active .step:nth-child(3) .sheen{animation-delay:1s}
  @keyframes sheen{0%{transform:translateX(-100%)}50%,100%{transform:translateX(100%)}}

  /* ---- payoff pillars ---- */
  .pillars{display:flex;gap:20px;margin:42px 0 6px;flex-wrap:wrap}
  .pillar{flex:1;min-width:220px}
  .pillar .ic{width:46px;height:46px;border-radius:12px;background:var(--panel);border:1px solid var(--line);
    display:flex;align-items:center;justify-content:center;margin-bottom:16px}
  .pillar .ic svg{width:22px;height:22px}
  .pillar h3{font-family:var(--display);font-size:20px;font-weight:600;margin-bottom:8px}
  .pillar p{font-size:14.5px;color:var(--muted);line-height:1.5}
  .closing{font-family:var(--display);font-size:clamp(18px,2.4vw,26px);margin-top:40px;color:var(--text);font-weight:500;line-height:1.4}

  /* ---- chrome: progress, nav, counter ---- */
  .progress{position:fixed;top:0;left:0;height:3px;background:linear-gradient(90deg,var(--gold),var(--cyan));z-index:5;transition:width .5s ease;width:0}
  .nav{position:fixed;bottom:26px;right:30px;z-index:5;display:flex;gap:10px}
  .nav button{width:46px;height:46px;border-radius:50%;border:1px solid var(--line);background:rgba(20,30,51,.7);
    backdrop-filter:blur(6px);color:var(--text);cursor:pointer;font-size:18px;display:flex;align-items:center;justify-content:center;transition:.2s}
  .nav button:hover{border-color:var(--cyan);color:var(--cyan)}
  .nav button:disabled{opacity:.3;cursor:default}
  .counter{position:fixed;bottom:32px;left:30px;z-index:5;font-family:var(--mono);font-size:13px;color:var(--muted);letter-spacing:.1em}
  .dots{position:fixed;bottom:34px;left:50%;transform:translateX(-50%);z-index:5;display:flex;gap:10px}
  .dots button{width:8px;height:8px;border-radius:50%;border:none;background:var(--line);cursor:pointer;padding:0;transition:.25s}
  .dots button.on{background:var(--cyan);width:22px;border-radius:5px}
  .hint{position:fixed;bottom:32px;left:50%;transform:translate(-50%,40px);z-index:5;font-family:var(--mono);font-size:12px;color:var(--muted);opacity:0;transition:opacity .4s}
  .hint.show{opacity:.7}

  /* ---- public vs permissioned ---- */
  .compare{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin:38px 0 8px}
  .col{background:var(--panel);border:1px solid var(--line);border-radius:18px;padding:26px 28px;position:relative}
  .col.perm{border-color:rgba(95,211,196,.5)}
  .col-tag{position:absolute;top:-12px;right:22px;background:var(--cyan);color:#072420;
    font-family:var(--mono);font-size:11px;font-weight:600;letter-spacing:.08em;padding:5px 13px;border-radius:999px;text-transform:uppercase}
  .col h3{font-family:var(--display);font-size:24px;font-weight:600;display:flex;align-items:baseline;gap:11px}
  .col.public h3{color:var(--gold)} .col.perm h3{color:var(--cyan)}
  .col h3 small{font-family:var(--mono);font-size:12px;color:var(--muted);font-weight:400;letter-spacing:.05em;text-transform:uppercase}
  .col-rows{margin-top:20px;display:flex;flex-direction:column;gap:15px}
  .crow{display:grid;grid-template-columns:104px 1fr;gap:14px;align-items:baseline}
  .crow .k{font-family:var(--mono);font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}
  .crow .v{font-size:16px;color:var(--text);line-height:1.4}

  @media (max-width:680px){
    .nav{bottom:18px;right:16px} .counter{bottom:24px;left:16px} .dots{bottom:auto;top:18px}
    .banks{gap:14px} .steps{flex-direction:column} .compare{grid-template-columns:1fr}
  }
  @media (prefers-reduced-motion: reduce){
    *{animation:none!important;transition:opacity .2s ease!important}
    #bg{display:none}
  }
</style>
</head>
<body>
<canvas id="bg"></canvas>
<div class="progress" id="progress"></div>

<div class="deck" id="deck">

  <!-- 1. TITLE -->
  <section class="slide active">
    <div class="wrap">
      <div class="eyebrow" data-reveal>UAE Banking &nbsp;·&nbsp; Conceptual Demo</div>
      <h1 class="title-xl" data-reveal>Interbank Fraud<br><span class="gold">Intelligence Network</span></h1>
      <p class="lead" data-reveal>How banks can warn each other about fraud — <span class="cyan">without ever sharing your private data.</span></p>
      <div class="meta-row" data-reveal>
        <span class="chip">Privacy-preserving</span>
        <span class="chip">Shared &amp; tamper-proof</span>
        <span class="chip">No central authority</span>
      </div>
    </div>
  </section>

  <!-- 2. PROBLEM -->
  <section class="slide">
    <div class="wrap">
      <div class="eyebrow" data-reveal>The Problem</div>
      <h2 data-reveal>Fraud moves faster than banks talk</h2>
      <div class="banks" data-reveal>
        <div class="bank"><div class="hop"></div>
          <svg viewBox="0 0 24 24" fill="none" stroke="#8294B0" stroke-width="1.6"><path d="M3 21h18M5 21V10m14 11V10M3 10l9-6 9 6M9 21v-6h6v6"/></svg>
          <span>Bank A</span></div>
        <div class="bank-line"></div>
        <div class="bank">
          <svg viewBox="0 0 24 24" fill="none" stroke="#8294B0" stroke-width="1.6"><path d="M3 21h18M5 21V10m14 11V10M3 10l9-6 9 6M9 21v-6h6v6"/></svg>
          <span>Bank B</span></div>
        <div class="bank-line"></div>
        <div class="bank">
          <svg viewBox="0 0 24 24" fill="none" stroke="#8294B0" stroke-width="1.6"><path d="M3 21h18M5 21V10m14 11V10M3 10l9-6 9 6M9 21v-6h6v6"/></svg>
          <span>Bank C</span></div>
      </div>
      <p class="sub" data-reveal>A scammer caught at one bank simply walks over to the next and tries again. Each bank only sees its own corner — by the time everyone connects the dots, the money is gone.</p>
    </div>
  </section>

  <!-- 3. WHY THEY CAN'T SHARE -->
  <section class="slide">
    <div class="wrap">
      <div class="eyebrow" data-reveal>The Catch</div>
      <h2 data-reveal>So why don't they just share a list?</h2>
      <div class="swap" data-reveal>
        <div class="doc">Name: <b>•••••••</b><br>Emirates ID: <b>784-••••</b><br>Account: <b>AE•• ••••</b></div>
        <div class="barrier"><div class="ban"></div><small>NOT ALLOWED</small></div>
        <div class="doc">Name: <b>•••••••</b><br>Emirates ID: <b>784-••••</b><br>Account: <b>AE•• ••••</b></div>
      </div>
      <p class="sub" data-reveal>Sharing real names, ID numbers and account details would break privacy law and expose every customer. So banks stay silent — and the fraudster wins.</p>
    </div>
  </section>

  <!-- 4. THE IDEA -->
  <section class="slide">
    <div class="wrap">
      <div class="eyebrow" data-reveal>The Idea</div>
      <h2 data-reveal>Share the <span class="cyan">warning</span>,<br>not the <span class="gold">person</span>.</h2>
      <p class="lead" data-reveal>One shared network where any bank can raise a fraud flag — while the identity behind it stays completely hidden, even from the other banks.</p>
    </div>
  </section>

  <!-- 5. TOKENIZER (signature) -->
  <section class="slide">
    <div class="wrap">
      <div class="eyebrow" data-reveal>How It Stays Private</div>
      <h2 data-reveal>Turn identity into an unreadable fingerprint</h2>
      <div class="tok" data-reveal>
        <div class="tok-card tok-id">
          <div class="label">Real identity</div>
          <div class="tok-val">784-1990-•••••</div>
        </div>
        <div class="arrow">
          <div class="lock"><svg viewBox="0 0 24 24" fill="none" stroke-width="1.8"><rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/></svg></div>
          <div class="track"><span class="pulse"></span></div>
          <div class="one-way">one-way · can't reverse</div>
        </div>
        <div class="tok-card tok-out">
          <div class="label">Shared token</div>
          <div class="tok-val" id="tokenOut">a3f9c7e2b1</div>
        </div>
      </div>
      <p class="sub" data-reveal>Each identity is scrambled into a unique code that <span class="gold">cannot be turned back</span> into the original. Two banks holding the same code know it's the same person — but neither can read who. <em>Like comparing locked boxes: they match if the contents match, yet no one can open them.</em></p>
    </div>
  </section>

  <!-- 6. LEDGER -->
  <section class="slide">
    <div class="wrap">
      <div class="eyebrow" data-reveal>The Shared Record</div>
      <h2 data-reveal>One shared notebook no one can secretly edit</h2>
      <div class="ledger" data-reveal>
        <div class="row-led"><span class="dot"></span><span class="h">a3f9c7e2b1</span><span>flagged · card fraud</span><span class="t">09:14</span></div>
        <div class="row-led"><span class="dot"></span><span class="h">7b1d04f8aa</span><span>flagged · account takeover</span><span class="t">09:21</span></div>
        <div class="row-led"><span class="dot"></span><span class="h">e2c5901fab</span><span>flagged · mule account</span><span class="t">09:33</span></div>
      </div>
      <div class="chain-note" data-reveal>
        <div><b>Every bank</b> sees the same record</div>
        <div><b>No single bank</b> controls it</div>
        <div><b>Nothing</b> can be quietly changed</div>
      </div>
      <p class="sub" data-reveal>It's invite-only — just the member banks and the regulator. That's all "permissioned blockchain" really means.</p>
    </div>
  </section>

  <!-- 7. PUBLIC VS PERMISSIONED -->
  <section class="slide">
    <div class="wrap">
      <div class="eyebrow" data-reveal>Two Flavours</div>
      <h2 data-reveal>Public vs permissioned blockchain</h2>
      <div class="compare" data-reveal>
        <div class="col public">
          <h3>Public <small>open to all</small></h3>
          <div class="col-rows">
            <div class="crow"><span class="k">Who joins</span><span class="v">Anyone, anywhere in the world</span></div>
            <div class="crow"><span class="k">Who sees it</span><span class="v">The whole public</span></div>
            <div class="crow"><span class="k">Speed</span><span class="v">Slower — a huge crowd must agree</span></div>
            <div class="crow"><span class="k">Example</span><span class="v">Bitcoin, Ethereum</span></div>
          </div>
        </div>
        <div class="col perm">
          <span class="col-tag">What we use</span>
          <h3>Permissioned <small>invite-only</small></h3>
          <div class="col-rows">
            <div class="crow"><span class="k">Who joins</span><span class="v">Vetted members only</span></div>
            <div class="crow"><span class="k">Who sees it</span><span class="v">Only the member banks &amp; regulator</span></div>
            <div class="crow"><span class="k">Speed</span><span class="v">Fast — a small, known group</span></div>
            <div class="crow"><span class="k">Example</span><span class="v">This fraud network</span></div>
          </div>
        </div>
      </div>
      <p class="sub" data-reveal>Banks need privacy and known participants — so an invite-only network fits, never a public one.</p>
    </div>
  </section>

  <!-- 8. IN ACTION -->
  <section class="slide">
    <div class="wrap">
      <div class="eyebrow" data-reveal>In Action</div>
      <h2 data-reveal>A flag at one bank protects them all</h2>
      <div class="steps" data-reveal>
        <div class="step"><div class="sheen"></div><div class="n">01</div><h3>Bank A spots fraud</h3><p>It raises a flag — sending only the scrambled token to the network.</p></div>
        <div class="step"><div class="sheen"></div><div class="n">02</div><h3>Network shares it</h3><p>The flag appears on the shared ledger instantly, for every member bank.</p></div>
        <div class="step"><div class="sheen"></div><div class="n">03</div><h3>Bank B is protected</h3><p>When that same token shows up at Bank B, it acts <em>before</em> losing money.</p></div>
      </div>
    </div>
  </section>

  <!-- 8. PAYOFF -->
  <section class="slide">
    <div class="wrap">
      <div class="eyebrow" data-reveal>Why It Matters</div>
      <h2 data-reveal>Faster detection. Full privacy. No middleman.</h2>
      <div class="pillars" data-reveal>
        <div class="pillar">
          <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="#5FD3C4" stroke-width="1.7"><path d="M12 2v4m0 12v4m10-10h-4M6 12H2m15.07-5.07-2.83 2.83M9.76 14.24l-2.83 2.83m0-10.14 2.83 2.83m4.48 4.48 2.83 2.83"/></svg></div>
          <h3 class="cyan">Seconds, not weeks</h3>
          <p>Fraud is caught across banks in real time, not after the loss.</p>
        </div>
        <div class="pillar">
          <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="#E8C07D" stroke-width="1.7"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
          <h3 class="gold">Privacy intact</h3>
          <p>Customer data never leaves the bank — only unreadable tokens travel.</p>
        </div>
        <div class="pillar">
          <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="#5FD3C4" stroke-width="1.7"><circle cx="12" cy="12" r="3"/><circle cx="5" cy="6" r="2"/><circle cx="19" cy="6" r="2"/><circle cx="5" cy="18" r="2"/><circle cx="19" cy="18" r="2"/><path d="M7 7l3 3m7-3-3 3m-4 4-3 3m10-3-3-3"/></svg></div>
          <h3 class="cyan">No central owner</h3>
          <p>No middleman to trust, bribe, or hack — the network belongs to all.</p>
        </div>
      </div>
      <p class="closing" data-reveal>Banks fighting fraud <span class="gold">together</span> — without giving up a single customer's <span class="cyan">privacy</span>.</p>
    </div>
  </section>

</div>

<div class="counter" id="counter">01 / 08</div>
<div class="dots" id="dots"></div>
<div class="hint" id="hint">← → or space to move</div>
<div class="nav">
  <button id="prev" aria-label="Previous">‹</button>
  <button id="next" aria-label="Next">›</button>
</div>

<script>
(function(){
  const slides=[...document.querySelectorAll('.slide')];
  const total=slides.length;
  let i=0;
  const progress=document.getElementById('progress');
  const counter=document.getElementById('counter');
  const dotsWrap=document.getElementById('dots');
  const prev=document.getElementById('prev');
  const next=document.getElementById('next');
  const hint=document.getElementById('hint');
  const pad=n=>String(n).padStart(2,'0');

  slides.forEach((_,n)=>{
    const b=document.createElement('button');
    b.addEventListener('click',()=>go(n));
    dotsWrap.appendChild(b);
  });
  const dots=[...dotsWrap.children];

  function go(n){
    i=Math.max(0,Math.min(total-1,n));
    slides.forEach((s,k)=>s.classList.toggle('active',k===i));
    dots.forEach((d,k)=>d.classList.toggle('on',k===i));
    progress.style.width=((i)/(total-1)*100)+'%';
    counter.textContent=pad(i+1)+' / '+pad(total);
    prev.disabled=i===0; next.disabled=i===total-1;
    if(i===4) scrambleToken();
  }
  function nextS(){go(i+1)} function prevS(){go(i-1)}

  prev.addEventListener('click',prevS);
  next.addEventListener('click',nextS);
  document.addEventListener('keydown',e=>{
    if(e.key==='ArrowRight'||e.key===' '||e.key==='PageDown'){e.preventDefault();nextS()}
    if(e.key==='ArrowLeft'||e.key==='PageUp'){e.preventDefault();prevS()}
    if(e.key==='Home')go(0); if(e.key==='End')go(total-1);
  });
  // touch swipe
  let sx=0;
  document.addEventListener('touchstart',e=>sx=e.touches[0].clientX,{passive:true});
  document.addEventListener('touchend',e=>{
    const dx=e.changedTouches[0].clientX-sx;
    if(Math.abs(dx)>50){dx<0?nextS():prevS()}
  },{passive:true});

  // token scramble animation
  const out=document.getElementById('tokenOut');
  const final='a3f9c7e2b1';
  const chars='0123456789abcdef';
  let scrambleTimer=null;
  function scrambleToken(){
    if(window.matchMedia('(prefers-reduced-motion: reduce)').matches){out.textContent=final;return;}
    clearInterval(scrambleTimer);
    let frame=0;
    scrambleTimer=setInterval(()=>{
      frame++;
      const locked=Math.floor(frame/3);
      let s='';
      for(let k=0;k<final.length;k++){
        s+= k<locked ? final[k] : chars[Math.floor(Math.random()*chars.length)];
      }
      out.textContent=s;
      if(locked>=final.length){clearInterval(scrambleTimer);out.textContent=final;}
    },45);
  }

  // ambient network background
  const cv=document.getElementById('bg'),ctx=cv.getContext('2d');
  let W,H,nodes=[],raf;
  const reduce=window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  function resize(){W=cv.width=innerWidth;H=cv.height=innerHeight;}
  function init(){
    const count=Math.min(46,Math.floor(W*H/30000));
    nodes=Array.from({length:count},()=>({
      x:Math.random()*W,y:Math.random()*H,
      vx:(Math.random()-.5)*.25,vy:(Math.random()-.5)*.25
    }));
  }
  function draw(){
    ctx.clearRect(0,0,W,H);
    for(const n of nodes){
      n.x+=n.vx;n.y+=n.vy;
      if(n.x<0||n.x>W)n.vx*=-1;
      if(n.y<0||n.y>H)n.vy*=-1;
    }
    for(let a=0;a<nodes.length;a++){
      for(let b=a+1;b<nodes.length;b++){
        const dx=nodes[a].x-nodes[b].x,dy=nodes[a].y-nodes[b].y;
        const d=Math.hypot(dx,dy);
        if(d<150){
          ctx.strokeStyle='rgba(95,211,196,'+(0.10*(1-d/150))+')';
          ctx.lineWidth=1;
          ctx.beginPath();ctx.moveTo(nodes[a].x,nodes[a].y);ctx.lineTo(nodes[b].x,nodes[b].y);ctx.stroke();
        }
      }
    }
    for(const n of nodes){
      ctx.fillStyle='rgba(130,148,176,.35)';
      ctx.beginPath();ctx.arc(n.x,n.y,1.5,0,7);ctx.fill();
    }
    raf=requestAnimationFrame(draw);
  }
  if(!reduce){resize();init();draw();addEventListener('resize',()=>{cancelAnimationFrame(raf);resize();init();draw();});}

  go(0);
  setTimeout(()=>hint.classList.add('show'),900);
  setTimeout(()=>hint.classList.remove('show'),5000);
})();
</script>
</body>
</html>
